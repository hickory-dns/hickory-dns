{% if dot %}
tls local-tls {
    key-file "{{ dot.private_key }}";
    cert-file "{{ dot.cert_chain }}";
};
{% endif %}

{% if tsig_key %}
key "{{ tsig_key.name }}" {
  algorithm {{ tsig_key.algorithm }};
  secret "{{ tsig_key.secret_key }}";
};
{% endif %}

options {
    directory "/var/cache/bind";
    pid-file "/tmp/named.pid";
    recursion no;
    dnssec-validation no;
    allow-transfer { none; };
    # significantly reduces noise in logs
    empty-zones-enable no;

    listen-on port 53 { any; };
    {% if dot %}
    listen-on port 853 tls local-tls { any; };
    {% endif %}
};

zone "{{ fqdn }}" IN {
     type primary;
     file "/etc/zones/main.zone";
     {% if tsig_key %}
     allow-update { any; key "{{ tsig_key.name }}"; };
     allow-transfer { any; key "{{ tsig_key.name }}"; };
     {% endif %}
};

{% for zone in additional_zones -%}
zone "{{ zone }}" IN {
    type primary;
    file "/etc/zones/{{ zone }}zone";
    {% if tsig_key %}
    allow-update { any; key "{{ tsig_key.name }}"; };
    allow-transfer { any; key "{{ tsig_key.name }}"; };
    {% endif %}
};
{% endfor -%}
